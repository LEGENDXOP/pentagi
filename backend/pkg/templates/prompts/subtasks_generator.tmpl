<task_context>
  <instruction>
  Your goal is to generate optimized subtasks that will accomplish the PRIMARY USER REQUEST provided in the <user_task><input> field below.
  
  The <user_task><input> contains the MAIN OBJECTIVE that the user requested - this is the ultimate goal you must achieve.
  All subtasks you create MUST be designed to work together to accomplish this exact user request.
  Focus your subtasks on solving what the user asked for in <user_task><input>, not on tangential activities.

  ⚠️ SCOPE ENFORCEMENT: Each exploitation subtask MUST target exactly ONE vulnerability class.
  NEVER combine multiple vulnerability types (e.g., SSRF + IDOR + OAuth) in a single subtask.
  Multi-class subtasks have a 95% timeout rate. Split them into separate single-class subtasks.
  </instruction>

  <user_task>
    <input>{{.Task.Input}}</input>
  </user_task>

  {{if .Tasks}}
  <previous_tasks>
    {{range .Tasks}}
    <task>
      <id>{{.ID}}</id>
      <input>{{.Input}}</input>
      <status>{{.Status}}</status>
      <result>{{.Result}}</result>
    </task>
    {{end}}
  </previous_tasks>
  {{end}}

  {{if .Subtasks}}
  <previous_subtasks>
    {{range .Subtasks}}
    <subtask>
      <task_id>{{.TaskID}}</task_id>
      <id>{{.ID}}</id>
      <title>{{.Title}}</title>
      <description>{{.Description}}</description>
      <status>{{.Status}}</status>
      <result>{{.Result}}</result>
    </subtask>
    {{end}}
  </previous_subtasks>
  {{end}}

  {{if .WorkspaceFiles}}
  <workspace_state>
    <description>Files already present in the working directory. Consider these when planning — avoid re-creating work that already exists.</description>
    <working_directory>{{.Cwd}}</working_directory>
    {{range .WorkspaceFiles}}
    <file>
      <path>{{.Path}}</path>
      <size>{{.Size}}</size>
      <modified>{{.Modified}}</modified>
    </file>
    {{end}}
  </workspace_state>
  {{end}}

  {{if .ExecutionState}}
  <execution_state>
  {{.ExecutionState}}
  </execution_state>
  {{end}}

  {{if .MethodologyCoverage}}
  <methodology_coverage>
  {{.MethodologyCoverage}}
  When generating subtasks, ensure coverage of ALL uncovered P0 categories.
  </methodology_coverage>
  {{end}}

  {{if .ExecutionLogs}}
  <execution_logs>
  {{.ExecutionLogs}}
  </execution_logs>
  {{end}}
</task_context>
